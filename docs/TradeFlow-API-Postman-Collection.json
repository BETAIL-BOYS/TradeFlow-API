{
	"info": {
		"_postman_id": "tradeflow-api-collection",
		"name": "TradeFlow API",
		"description": "Complete API collection for TradeFlow RWA Backend. This collection includes all available endpoints for testing the TradeFlow protocol backend service.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health & Status",
			"item": [
				{
					"name": "Health Check (Ping)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Check the health status of the API and database connection. Returns service status and database connectivity information."
					},
					"response": []
				}
			],
			"description": "Health check and status monitoring endpoints"
		},
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Get Auth Challenge",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/challenge",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "challenge"]
						},
						"description": "Generate a nonce for wallet-based authentication challenge. This nonce should be signed by the user's wallet and used in the login endpoint."
					},
					"response": []
				},
				{
					"name": "Login with Wallet Signature",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"publicKey\": \"GD5DQJZQJXGZJLQJQJQJQJQJQJQJQJQJQJQJQJQJQJQJQJQJQJQ\",\n  \"signature\": \"signature_of_nonce\",\n  \"nonce\": \"generated_nonce_from_challenge\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Authenticate using wallet signature. Provide the public key, signature of the nonce, and the nonce itself to receive a JWT token."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints for wallet-based login"
		},
		{
			"name": "Tokens",
			"item": [
				{
					"name": "Get All Tokens",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/tokens",
							"host": ["{{baseUrl}}"],
							"path": ["tokens"]
						},
						"description": "Retrieve all available tokens in the TradeFlow system. This endpoint returns a list of supported tokens with their metadata."
					},
					"response": []
				},
				{
					"name": "Get Token by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/tokens/:tokenId",
							"host": ["{{baseUrl}}"],
							"path": ["tokens", ":tokenId"]
						},
						"description": "Retrieve specific token information by token ID. Replace :tokenId with the actual token identifier."
					},
					"response": []
				}
			],
			"description": "Token management endpoints (planned feature)"
		},
		{
			"name": "Prices",
			"item": [
				{
					"name": "Get All Prices",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/prices",
							"host": ["{{baseUrl}}"],
							"path": ["prices"]
						},
						"description": "Retrieve current prices for all supported tokens and assets in the TradeFlow system."
					},
					"response": []
				},
				{
					"name": "Get Price by Token",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/prices/:tokenId",
							"host": ["{{baseUrl}}"],
							"path": ["prices", ":tokenId"]
						},
						"description": "Retrieve current price for a specific token. Replace :tokenId with the actual token identifier."
					},
					"response": []
				}
			],
			"description": "Price information endpoints (planned feature)"
		},
		{
			"name": "Invoices",
			"item": [
				{
					"name": "Get All Invoices",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/invoices",
							"host": ["{{baseUrl}}"],
							"path": ["invoices"]
						},
						"description": "Retrieve all processed invoices from the system. Returns a list of invoices with their current status and details."
					},
					"response": []
				},
				{
					"name": "Create New Invoice",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"invoiceNumber\": \"INV-2024-001\",\n  \"amount\": 10000,\n  \"dueDate\": \"2024-12-31\",\n  \"issuer\": \"Company Name\",\n  \"recipient\": \"Recipient Company\",\n  \"description\": \"Invoice for services rendered\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/invoices",
							"host": ["{{baseUrl}}"],
							"path": ["invoices"]
						},
						"description": "Create a new invoice for risk assessment and processing. The invoice will be evaluated by the risk engine and stored in the system."
					},
					"response": []
				},
				{
					"name": "Parse PDF Invoice",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/invoices/parse",
							"host": ["{{baseUrl}}"],
							"path": ["invoices", "parse"]
						},
						"description": "Upload and parse a PDF invoice to extract total amount and due date automatically using OCR technology."
					},
					"response": []
				},
				{
					"name": "Test Error Handling",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwtToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/invoices/test-error",
							"host": ["{{baseUrl}}"],
							"path": ["invoices", "test-error"]
						},
						"description": "Test endpoint to verify global error handling. This deliberately throws an error to test the error handling mechanism."
					},
					"response": []
				}
			],
			"description": "Invoice management and processing endpoints"
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"description": "Base URL for the TradeFlow API"
		},
		{
			"key": "jwtToken",
			"value": "",
			"description": "JWT token obtained from authentication. Set this after successful login."
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	]
}
